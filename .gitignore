# ============================================================
# PHYLUM .gitignore — keeps the repo clean for public release
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg-info/
*.egg
*.manifest
*.spec

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/
.venv_pkgs.txt
venv_pkgs.txt

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~

# ── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Environment & secrets (NEVER commit) ────────────────────
.env
.env.*
secrets.json
credentials.json
*.pem
*.key

# ── Databases (runtime state, not source) ───────────────────
*.db
*.sqlite3
agent_state.db

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Test caches ─────────────────────────────────────────────
.pytest_cache/
coverage.xml
htmlcov/
.coverage

# ── Build artifacts — Python (PyInstaller) ──────────────────
.build/
build/
dist/
*.exe
*.msi

# ── Build artifacts — Rust / Tauri ──────────────────────────
frontend/src-tauri/target/
frontend/src-tauri/binaries/*.exe
frontend/src-tauri/gen/schemas/

# ── Build artifacts — Frontend ──────────────────────────────
frontend/dist/
frontend/node_modules/
node_modules/

# ── LanceDB / Vector data (runtime, rebuilt on first use) ───
lance_data/
*.lance

# ── Agent workspace (user runtime data) ─────────────────────
agent_workspace/

# ── Package lock files (optional — reproducible builds) ─────
# Uncomment if you prefer NOT to track lock files:
# package-lock.json
# frontend/package-lock.json
# frontend/src-tauri/Cargo.lock

# ── Misc temp files ─────────────────────────────────────────
*.tmp
*.bak
*.orig
