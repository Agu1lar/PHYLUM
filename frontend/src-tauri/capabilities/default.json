{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capabilities for Agente Desktop.",
  "windows": [
    "main",
    "approval-widget"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/agente-backend",
          "sidecar": true
        }
      ]
    }
  ]
}
