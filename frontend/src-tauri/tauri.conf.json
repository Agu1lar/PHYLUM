{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "phylum",
  "version": "0.1.0",
  "identifier": "com.phylum.app",
  "build": {
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File ../build_backend_sidecar.ps1 && npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PHYLUM",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "externalBin": [
      "binaries/agente-backend"
    ]
  }
}